---
const t = Astro.locals.t;
const locale = Astro.locals.starlightRoute.locale;
const base = locale ? `/redmine-cli/${locale}` : '/redmine-cli';

const capabilities = [
  {
    code: 'ISS',
    title: t('capability.issues.title'),
    desc: t('capability.issues.desc'),
    href: `${base}/commands/issues/`,
  },
  {
    code: 'TIM',
    title: t('capability.time.title'),
    desc: t('capability.time.desc'),
    href: `${base}/commands/time/`,
  },
  {
    code: 'PRJ',
    title: t('capability.projects.title'),
    desc: t('capability.projects.desc'),
    href: `${base}/commands/projects/`,
  },
  {
    code: 'RES',
    title: t('capability.names.title'),
    desc: t('capability.names.desc'),
    href: `${base}/getting-started/quick-start/${t('capability.names.anchor')}`,
  },
  {
    code: 'FMT',
    title: t('capability.formats.title'),
    desc: t('capability.formats.desc'),
    href: `${base}/guides/output-formats/`,
  },
  {
    code: 'AGT',
    title: t('capability.agents.title'),
    desc: t('capability.agents.desc'),
    href: `${base}/guides/ai-agents/`,
  },
];
---

<div class="rc-matrix not-content">
  {capabilities.map((cap, i) => (
    <a class="rc-matrix__item" href={cap.href}>
      <div class="rc-matrix__head">
        <span class="rc-matrix__num">{String(i + 1).padStart(2, '0')}</span>
        <span class="rc-matrix__code">{cap.code}</span>
        <span class="rc-matrix__arrow" aria-hidden="true">→</span>
      </div>
      <h3 class="rc-matrix__title">{cap.title}</h3>
      <p class="rc-matrix__desc">{cap.desc}</p>
    </a>
  ))}
</div>
