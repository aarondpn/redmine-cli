---
// Build-time fetch of latest release + repo meta.
// Fails gracefully if GH rate-limits or network unavailable.
type Repo = { stargazers_count?: number; license?: { spdx_id?: string } | null };
type Release = { tag_name?: string; published_at?: string };

const repoUrl = 'https://api.github.com/repos/aarondpn/redmine-cli';
const releaseUrl = `${repoUrl}/releases/latest`;

async function safeFetch<T>(url: string): Promise<T | null> {
  try {
    const res = await fetch(url, { headers: { Accept: 'application/vnd.github+json' } });
    if (!res.ok) return null;
    return (await res.json()) as T;
  } catch {
    return null;
  }
}

const [repo, release] = await Promise.all([
  safeFetch<Repo>(repoUrl),
  safeFetch<Release>(releaseUrl),
]);

const version = release?.tag_name ?? 'latest';
const stars = repo?.stargazers_count ?? null;
const license = repo?.license?.spdx_id ?? 'MIT';
const released = release?.published_at
  ? new Date(release.published_at).toISOString().slice(0, 10)
  : null;
const t = Astro.locals.t;
---

<div class="status-bar not-content" role="status" aria-label={t('hero.statusAriaLabel')}>
  <div class="status-cell">
    <span class="status-key">{t('hero.ver')}</span>
    <span class="status-val">{version}</span>
  </div>
  {released && (
    <div class="status-cell status-cell--hide-sm">
      <span class="status-key">{t('hero.build')}</span>
      <span class="status-val">{released}</span>
    </div>
  )}
  <div class="status-cell status-cell--hide-sm">
    <span class="status-key">{t('hero.lic')}</span>
    <span class="status-val">{license}</span>
  </div>
  {stars !== null && (
    <a
      class="status-cell status-cell--link"
      href="https://github.com/aarondpn/redmine-cli/stargazers"
      target="_blank"
      rel="noopener"
    >
      <span class="status-key">{t('hero.stars')}</span>
      <span class="status-val">{stars.toLocaleString()}</span>
    </a>
  )}
  <div class="status-cell status-cell--grow" aria-hidden="true"></div>
  <div class="status-cell status-clock">
    <span class="status-key">{t('hero.sys')}</span>
    <span class="status-val">redmine/cli</span>
  </div>
</div>
