{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommitTypeAll(chore)",
    "helpers:pinGitHubActionDigests"
  ],
  "labels": ["dependencies"],
  "osvVulnerabilityAlerts": true,
  "minimumReleaseAge": "3 days",
  "schedule": ["before 9am on monday"],
  "timezone": "Europe/Berlin",
  "packageRules": [
    {
      "description": "Immediately open PRs for vulnerability fixes",
      "matchCategories": ["security"],
      "schedule": ["at any time"],
      "minimumReleaseAge": "0 days"
    },
    {
      "description": "Group Go dependency updates",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "go dependencies (non-major)"
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "github actions"
    },
    {
      "description": "Group docs dependencies",
      "matchFileNames": ["docs/**"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "docs dependencies (non-major)"
    }
  ]
}
